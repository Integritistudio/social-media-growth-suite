PORT=3001
DB_HOST=localhost
DB_USER=root
DB_PASS=your_mysql_password
DB_NAME=igs_db

# If saves fail with "Got a packet bigger than 'max_allowed_packet' bytes", raise MySQL packet size.
# See server/scripts/mysql-max-packet.sql — set [mysqld] max_allowed_packet=64M in my.ini and restart MySQL.
JWT_SECRET=change_this_to_a_long_random_secret_string
ENCRYPTION_KEY=0123456789abcdef0123456789abcdef0123456789abcdef0123456789abcdef

# OAuth (LinkedIn Sign In + posting)
CLIENT_ID=your_linkedin_app_client_id
PRIMARY_CLIENT_SECRET=your_linkedin_primary_client_secret
# Optional aliases: LINKEDIN_CLIENT_ID, LINKEDIN_CLIENT_SECRET
# Public URLs — required for OAuth redirects in production
CLIENT_URL=http://localhost:3000
SERVER_URL=http://localhost:3001

# LinkedIn automation worker (optional)
# REDIS_URL=redis://127.0.0.1:6379
# LINKEDIN_WORKER_POLL_MS=5000
# LINKEDIN_MAX_INVITES_CAP=50
# PLAYWRIGHT_HEADLESS=true
