PORT=3001
DB_HOST=localhost
DB_USER=root
DB_PASS=your_mysql_password
DB_NAME=igs_db

# If saves fail with "Got a packet bigger than 'max_allowed_packet' bytes", raise MySQL packet size.
# See server/scripts/mysql-max-packet.sql — set [mysqld] max_allowed_packet=64M in my.ini and restart MySQL.
JWT_SECRET=change_this_to_a_long_random_secret_string
ENCRYPTION_KEY=0123456789abcdef0123456789abcdef0123456789abcdef0123456789abcdef

# LinkedIn automation worker (optional)
# REDIS_URL=redis://127.0.0.1:6379
# LINKEDIN_WORKER_POLL_MS=5000
# LINKEDIN_MAX_INVITES_CAP=50
# PLAYWRIGHT_HEADLESS=true
